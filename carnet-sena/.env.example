# CONFIGURACIÓN DEL SISTEMA - SENA CARNET

# Llave secreta para seguridad (puedes cambiarla por algo complejo)
SECRET_KEY=sena_carnet_secure_key_2024_ag_v1

# Configuración de Base de Datos (SQLite por defecto)
DATABASE_URL=sqlite:///instance/carnets.sqlite

# --- CONFIGURACIÓN DE CORREO (SMTP) ---
# Si usas Gmail:
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
# IMPORTANTE: Si usas Gmail con 2FA, debes generar una "Contraseña de Aplicación"
# No uses tu contraseña normal de Gmail.
MAIL_PASSWORD=tu_contraseña_de_aplicacion
